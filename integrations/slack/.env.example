OMNIGENT_SLACK_BOT_TOKEN=xoxb-your-bot-token
OMNIGENT_SLACK_APP_TOKEN=xapp-your-app-level-token
OMNIGENT_SERVER_URL=https://omnigent.example.com

# Optional runtime tuning
# LOG_LEVEL=INFO
# Where the bot's SQLite store lives. Defaults to
# $OMNIGENT_DATA_DIR/omnigent_slack.sqlite3 (or ~/.omnigent/omnigent_slack.sqlite3
# when OMNIGENT_DATA_DIR is unset). Set this to override.
# OMNIGENT_SLACK_DATABASE_PATH=

# Optional but strongly recommended: shared secret from Omnigent server
# Set it to the SAME value as the Omnigent server's
# OMNIGENT_DEVICE_CLIENT_SECRET; the bot then sends it on the device
# authorize/token/revoke calls (X-Omnigent-Client-Secret header) so the
# server only accepts this client. Leave unset when the server doesn't
# require it. Only meaningful in accounts mode (the OIDC flow doesn't use it).
# OMNIGENT_DEVICE_CLIENT_SECRET=

# The bot auto-detects the server's auth mode (via GET /v1/me, like
# the `omnigent login` CLI) and picks the matching login flow — no auth-mode
# config here:
#   • accounts → OAuth 2.0 device grant (a consent page in the browser).
#                Requires the Omnigent server to have the device grant enabled
#                (OMNIGENT_DEVICE_GRANT_ENABLED=1 on the server — it is
#                default-off), otherwise accounts-mode login can't complete.
#   • oidc     → the server's cli-login ticket flow (the user signs in at your
#                IdP; no device grant, no refresh token)
#   • header   → auto-detect can't drive it; use the Databricks web-auth mode
#                below when the server is deployed as a Databricks App.
# The Omnigent server's own OMNIGENT_OIDC_* / OMNIGENT_AUTH_* env vars decide
# its mode; the bot needs none of them.
#
# ── Databricks Apps web-auth (header/proxy-mode servers) ─────────────────
# Set this when the Omnigent server is a Databricks App (header mode): the
# Apps proxy asserts identity via a header the bot can't produce from a
# Socket-Mode event, so instead the bot runs a custom U2M OAuth app
# (authorization code + PKCE, offline_access) via an enrollment page it serves
# as its own Databricks App. Each Slack user signs in once and the bot gets a
# durable, refreshable token it forwards to the server. Register a custom OAuth
# app in the workspace with redirect URI <app-url>/auth/callback. See
# docs/DATABRICKS_APP_WEBAUTH_DESIGN.md.
# OMNIGENT_SLACK_SERVER_AUTH=databricks
# Custom OAuth app credentials (client id + secret).
# OMNIGENT_SLACK_DATABRICKS_CLIENT_ID=
# OMNIGENT_SLACK_DATABRICKS_CLIENT_SECRET=
# HMAC key signing the enrollment `state` — its own secret, separate from the
# OAuth client secret. At least 32 chars of real entropy (e.g. `openssl rand
# -hex 32`); a weak value is brute-forceable and lets an attacker forge a state.
# OMNIGENT_SLACK_DATABRICKS_STATE_SECRET=
# Workspace host the OAuth app is registered in. Defaults to the injected
# DATABRICKS_HOST; set only for a laptop run where it's unset.
# OMNIGENT_SLACK_DATABRICKS_WORKSPACE_HOST=
# Requested scopes (space-separated). Defaults to all-apis; openid +
# offline_access are always added. Narrow it as far as the server proxy allows.
# OMNIGENT_SLACK_DATABRICKS_SCOPES=
# Public base URL of this bot's own Databricks App (the enrollment link base +
# OAuth redirect URI). Defaults to the injected DATABRICKS_APP_URL.
# OMNIGENT_SLACK_WEBAUTH_BASE_URL=
# Port the enrollment web server binds. Defaults to DATABRICKS_APP_PORT (8000).
# OMNIGENT_SLACK_WEBAUTH_PORT=
#
# A Fernet key that encrypts each user's delegated token at rest so a stolen
# database file can't impersonate them — generate one with:
#   uv run python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# If unset, tokens are kept in memory only (never written to disk) and lost on
# restart, so users re-authenticate; the integration still works.
# OMNIGENT_SLACK_TOKEN_ENCRYPTION_KEY=
